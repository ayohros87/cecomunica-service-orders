{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "tools/**",
      "mejoras solicitadas/**"
    ],
    "rewrites": [
      {
        "source": "/api/sendMail",
        "function": "sendMail"
      },
      {
        "source": "/api/quickbooks/connect",
        "function": "quickbooksOAuth"
      },
      {
        "source": "/api/quickbooks/callback",
        "function": "quickbooksOAuth"
      },
      {
        "source": "/api/quickbooks/disconnect",
        "function": "quickbooksOAuth"
      },
      {
        "source": "/api/quickbooks/webhook",
        "function": "quickbooksWebhook"
      },
      { "source": "/c/**", "destination": "/verify/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "storage": { "port": 9199 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}
