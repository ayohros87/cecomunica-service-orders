# it commented so all members can deploy to the same project(s) in .firebaserc.
# .firebaserc

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env

# dataconnect generated files
.dataconnect

# Claude Code local session state — machine-specific
.claude/

# Secret and credential files — never commit
firebase config firma secret.txt
api- sendgrid.txt
*secret*.txt
*credential*.txt
*password*.txt

# QuickBooks Online tokens — never commit (local discovery/dev only)
qbo.local.json
*.local.json

# Local backup archives created by backup_cecomunica_v2.txt
backups/

# Downloaded zip exports / one-shot artifacts — should never be in the repo
*.zip

# Manuales / documentos binarios — no se versionan en el repo
Manual_Facturacion_CECOMUNICA.pdf

# Prompts de trabajo one-shot (notas locales, no son parte del código)
PROMPT_*.md

# Fotos fuente de los handoffs de diseño: PNG de ~2 MB cada una, pensadas para
# mirarse una vez y derivar de ellas los assets reales. Las versiones optimizadas
# que sirve la app (public/img/) sí se versionan — son las que importan. Regla
# acotada a assets/photos/ a propósito: el resto de PNG de design-system son
# iconos y logos que sí van al repo.
design-system/**/assets/photos/

# Data local-only (confidencial o irreproducible): fuente Excel del módulo KPI,
# referencias de diseño con data real. Vive fuera de public/ para no depender
# del hosting.ignore; el backup .bat SÍ la respalda.
local-data/
