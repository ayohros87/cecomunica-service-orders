rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───────────────────────────────────────────────────────────────────────
    // BORRADOR — reglas explícitas por colección (sin catch-all).
    //
    // CONTEXTO: hasta ahora existía un catch-all `match /{document=**}` que
    // concedía read+write a todo usuario autenticado. Por la semántica OR de
    // Firestore (si CUALQUIER match concede, se permite) ese catch-all
    // SOMBREABA las reglas más estrictas (usuarios, contratos) — eran inertes.
    // Para poder ENFORCAR scoping en `cotizaciones` hay que eliminar el
    // catch-all y enumerar cada colección; toda colección no listada queda
    // denegada por defecto.
    //
    // OBJETIVO DE ESTE CAMBIO: el ÚNICO endurecimiento real es `cotizaciones`
    // (+ cierre de escritura de `usuarios`/`usuarios_audit`, verificado sin
    // escrituras de cliente). El resto de colecciones conserva el
    // comportamiento efectivo de hoy (auth read+write) para no romper flujos.
    //
    // ⚠️ PROBAR EN EMULADOR / dry-run ANTES DE DESPLEGAR. Flujos a verificar:
    //   - cotizaciones: crear (vendedor), editar propia, aprobar (admin),
    //     enviar/cerrar, intentos cruzados vendedor↔vendedor (deben fallar en get).
    //   - contratos: linkOrden/unlinkOrden (subcolección ordenes), editar contrato.
    //   - usuarios: alta/edición vía callable manageUser (admin SDK, sigue OK).
    // ───────────────────────────────────────────────────────────────────────

    function isSignedIn() { return request.auth != null; }

    function userRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }
    function isAdmin()    { return isSignedIn() && userRole() == "administrador"; }
    // Cotizaciones: aprobación separada por TIPO (ver match /cotizaciones).
    //   puedeCotizar → crear/listar;  verTodasCot → ver/editar/borrar cualquiera (como admin).
    //   gerente: incluido para que pueda revisar y aprobar cotizaciones comerciales.
    function puedeCotizar() { return isSignedIn() && userRole() in ["administrador", "vendedor", "jefe_taller", "recepcion", "gerente"]; }
    function verTodasCot()  { return isSignedIn() && userRole() in ["administrador", "jefe_taller", "gerente"]; }
    // Gestión de seriales del contrato (subcolecciones seriales/seriales_estado/
    // seriales_historial). Refleja el permiso 'gestionar-seriales' de roles.js.
    // Cierra el hueco por el que CUALQUIER autenticado podía escribir seriales.
    // El candado fino "solo admin/allowlist tras asignados" vive en la UI
    // (contrato-seriales-page.js + empresa/config.seriales_editores_extra).
    function puedeGestionarSeriales() { return isSignedIn() && userRole() in ["administrador", "recepcion", "vendedor", "gerente", "inventario"]; }
    // Solicitar cambio/corrección de serial (recepción/admin) — solo mientras el
    // contrato está 'aprobado' (antes de activarse). Ver match /seriales_cambios.
    function puedeSolicitarCambioSerial() { return isSignedIn() && userRole() in ["administrador", "recepcion"]; }

    // Campos cuyo dueño exclusivo es Cloud Functions (admin SDK los salta).
    // Sólo bloquea escrituras desde el frontend que CAMBIEN estos campos. Se
    // evalúa sobre las claves AFECTADAS (diff), no sobre su mera presencia: en un
    // `update`, request.resource.data es el doc COMPLETO resultante, así que
    // comprobar `"X" in incoming` bloqueaba cualquier edición de un contrato que
    // ya tuviera firma_*/os_* estampados por la CF (aunque no se tocaran).
    //   NOTA: `fecha_aprobacion` NO va aquí — el frontend lo estampa al aprobar
    //   (contratos-approval.js); la CF onContratoActivado solo lo rellena/repara.
    function touchesCFOwnedFields() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasAny([
        "firma_codigo", "firma_hash", "firma_url",
        "os_count", "equipos_total", "tiene_os", "os_linked",
        "os_serials_preview", "os_has_equipos", "os_last_orden_id",
        "os_equipos_count_last", "os_dirty"
      ]);
    }

    // ── Usuarios ──────────────────────────────────────────────────────────
    // Lectura para cualquier autenticado (la app resuelve roles/nombres).
    // Escritura SOLO vía callable `manageUser` (admin SDK) → write:false en cliente.
    // Verificado: no hay db.collection('usuarios').set/update/add desde el frontend.
    match /usuarios/{userId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // Auditoría de usuarios — escrita por Cloud Functions (admin SDK).
    // El cliente sólo la lee (auditoriaService). write:false.
    match /usuarios_audit/{docId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ── Cotizaciones (ENFORCED) ───────────────────────────────────────────
    // Acceso: administrador y vendedor. El vendedor sólo accede a las propias
    // por id (get); la aprobación queda reservada a administradores.
    //
    // NOTA sobre `list`: el listado actual (cotizaciones-index) trae todas y
    // filtra "solo mías" en cliente, así que `list` se concede a todo el rol
    // ventas. Para AISLAR la lista por vendedor a nivel de reglas hace falta:
    //   1) que la query incluya .where('creado_por_uid','==',uid) para vendedores
    //      (cotizacionesService.listCotizaciones + busquedaGlobal),
    //   2) un índice compuesto (creado_por_uid ASC, fecha_creacion DESC),
    //   3) cambiar la regla `list` de abajo a la variante por-dueño.
    // El `get` por id YA está aislado (editar/detalle/imprimir por URL ajena fallan).
    match /cotizaciones/{docId} {
      function esDueno() {
        return isSignedIn() && resource.data.creado_por_uid == request.auth.uid;
      }
      // ¿La escritura intenta aprobar (transición a 'aprobada') o estampar
      // los campos de aprobación?
      function aprobacionTocada() {
        let after = request.resource.data;
        let changed = after.diff(resource.data).affectedKeys();
        return (after.estado == "aprobada" && resource.data.estado != "aprobada")
            || changed.hasAny(["fecha_aprobacion", "aprobado_por_uid"]);
      }
      // Tipo de cotización: 'orden' (servicio, sale de una orden de taller) vs
      // comercial. Las legacy sin `origen` se tratan como comerciales. Se lee del
      // doc EXISTENTE (resource), no del entrante, para que nadie eleve el tipo en
      // la misma escritura de aprobación (p.ej. comercial→'orden' para saltarse al gerente).
      function cotEsServicio() {
        return resource.data.get("origen", "comercial") == "orden";
      }
      // Técnicos de taller: PREPARAN cotizaciones de servicio (origen=orden) en
      // borrador desde una orden. No crean comerciales ni envían/aprueban: el
      // envío al cliente y la aprobación quedan para el supervisor (jefe_taller).
      function esTecnicoTaller() {
        return isSignedIn() && userRole() in ["tecnico", "tecnico_operativo"];
      }
      function entranteEsServicio() {
        return request.resource.data.get("origen", "comercial") == "orden";
      }

      allow get:  if verTodasCot() || esDueno();
      // `list` lo usa la generación del correlativo (nextCotizacionId); se concede
      // también a técnicos de taller para que el id no colisione al preparar.
      allow list: if puedeCotizar() || esTecnicoTaller();

      allow create: if (puedeCotizar() || (esTecnicoTaller() && entranteEsServicio()))
                     && request.resource.data.creado_por_uid == request.auth.uid
                     && (request.resource.data.estado == "borrador" || isAdmin());

      // Envío del dueño (estado→enviada) no es aprobacionTocada → vendedor envía lo
      // suyo. La APROBACIÓN se separa por tipo: servicio la aprueba el jefe de
      // mantenimiento (jefe_taller); comercial, el gerente; admin cualquiera.
      // Un técnico de taller solo puede mantener SU borrador (editarlo): no puede
      // moverlo a 'enviada' ni 'aprobada' — eso lo hace el supervisor.
      allow update: if (verTodasCot() || esDueno())
                     && (!esTecnicoTaller() || request.resource.data.estado == "borrador")
                     && (isAdmin()
                         || !aprobacionTocada()
                         || (userRole() == "jefe_taller" && cotEsServicio())
                         || (userRole() == "gerente" && !cotEsServicio()));

      allow delete: if verTodasCot();
    }

    // ── Cotizaciones públicas (sin cambios) ───────────────────────────────
    // Mirror público de cotizaciones aprobadas. Creado por la app autenticada
    // (admin que aprueba); leído por cualquiera con el code en el URL.
    match /cotizacion_verificaciones/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // Log de aperturas desde el link público. Cualquiera puede crear (POST simple,
    // no se expone PII más allá de user-agent/referrer). Lectura solo autenticada.
    match /cotizacion_opens/{logId} {
      allow create: if request.resource.data.keys().hasOnly(
                         ['verificacion_id', 'cotizacion_id', 'code',
                          'opened_at', 'user_agent', 'referrer'])
                       && request.resource.data.verificacion_id is string
                       && request.resource.data.code is string;
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    // ── Contratos (intención previa conservada) ───────────────────────────
    match /contratos/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && !touchesCFOwnedFields()
        && (!(resource.data.estado != "activo" && request.resource.data.estado == "activo")
            || (userRole() in ["administrador", "gerente"]));
      allow delete: if isSignedIn() && (userRole() in ["administrador", "gerente"]);

      // Lectura de CUALQUIER subcolección de contrato para autenticados (ordenes,
      // seriales, seriales_estado, seriales_historial, …). La escritura NO se
      // concede de forma recursiva: se otorga por subcolección más abajo, para
      // que las reglas específicas no queden sombreadas por el OR de Firestore.
      match /{sub=**} {
        allow read: if isSignedIn();
      }

      // Subcolección `ordenes` (cache de órdenes vinculadas). Además de las Cloud
      // Functions, el cliente escribe aquí vía contratosService.linkOrden() /
      // .unlinkOrden() (contratos-equipos.js, editar-orden.js).
      match /ordenes/{ordenId} {
        allow write: if isSignedIn();
      }

      // Seriales del contrato — escritura restringida al rol que los gestiona.
      // (El candado "solo admin/allowlist tras asignados" es adicional y vive en
      // la UI; a nivel de reglas basta con cerrar el rol.)
      match /seriales/{serialId}          { allow write: if puedeGestionarSeriales(); }
      match /seriales_estado/{docId2}     { allow write: if puedeGestionarSeriales(); }
      match /seriales_historial/{docId2}  { allow write: if puedeGestionarSeriales(); }

      // Solicitudes de cambio de serial. Crear: recepción/admin y SOLO mientras
      // el contrato está 'aprobado' (la ventana se cierra al activarse). Resolver
      // (estado→'resuelto') o cancelar: quien gestiona seriales (inventario,
      // recepción, admin, …). Borrar: admin.
      match /seriales_cambios/{reqId} {
        allow create: if puedeSolicitarCambioSerial()
                       && get(/databases/$(database)/documents/contratos/$(docId)).data.estado == "aprobado";
        allow update: if puedeGestionarSeriales();
        allow delete: if isAdmin();
      }
    }

    // ── Verificaciones de contratos (público, sin cambios) ────────────────
    match /verificaciones/{contratoId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Resto de colecciones — comportamiento preservado (auth read+write) ──
    // Estas NO se endurecen en este cambio (enfocado en cotizaciones). El
    // wildcard `{sub=**}` cubre subcolecciones (clientes/documentos,
    // ordenes_de_servicio/consumos, ordenes_de_servicio/equipos_meta, etc.).

    match /clientes/{docId} {
      allow read, write: if isSignedIn();
      match /{sub=**} { allow read, write: if isSignedIn(); }   // documentos
    }

    match /ordenes_de_servicio/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      // El cliente nunca hace hard-delete de una orden a nivel doc (verificado:
      // solo borra líneas de la subcolección `consumos`; los borrados de orden
      // pasan por consola/admin SDK y la CF onOrdenHardDelete limpia después).
      // Restringir delete a admin/gerente cierra el borrado de órdenes de negocio
      // por cualquier rol, sin afectar el borrado de consumos (regla sub=** abajo).
      allow delete: if isSignedIn() && userRole() in ["administrador","gerente"];
      match /{sub=**} { allow read, write: if isSignedIn(); }   // consumos, equipos_meta
    }

    match /poc_devices/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      // El cliente solo hace soft-delete (update deleted:true); el hard-delete a
      // nivel doc queda para admin.
      allow delete: if isAdmin();
      match /{sub=**} { allow read, write: if isSignedIn(); }
    }

    // Modelos: catálogo + tarifas de facturación (info sensible). Lectura para
    // cualquier autenticado (inventario cuenta stock, contratos eligen modelo).
    // Escritura SOLO admin/contabilidad (modelo-de-radio.html ya es admin-only).
    match /modelos/{docId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && userRole() in ["administrador", "contabilidad"];
    }
    // Cargos de facturación (activación, etc.) — info sensible, mismo criterio que modelos.
    match /cargos/{docId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && userRole() in ["administrador", "contabilidad"];
    }
    // Solicitudes de baja de equipos (cancelaciones de contrato).
    // Crear/ver: admin/gerente/vendedor/recepción. Aprobar/rechazar/borrar: admin/gerente.
    match /solicitudes_cancelacion/{docId} {
      allow read:   if isSignedIn() && userRole() in ["administrador","gerente","vendedor","recepcion"];
      allow create: if isSignedIn() && userRole() in ["administrador","gerente","vendedor","recepcion"];
      allow update: if isSignedIn() && userRole() in ["administrador","gerente"];
      allow delete: if isSignedIn() && userRole() in ["administrador","gerente"];
    }
    // empresa/config guarda parámetros sensibles: umbrales de auto-envío de
    // cotizaciones (descuento_max_pct, total_max), seriales_editores_extra
    // (allowlist que salta el candado de seriales) e itbms_rate (tasa fiscal).
    // Solo admin lo escribe. El resto de docs de empresa (estado_de_reparacion,
    // operadores, emisor, tecnicos…) es config operativa que el staff edita
    // desde las páginas de configuración, así que conserva write autenticado.
    match /empresa/{docId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && (docId != "config" || isAdmin());
    }
    match /inventario_actual/{docId}  { allow read, write: if isSignedIn(); }
    match /ultimo_inventario/{docId}  { allow read, write: if isSignedIn(); }
    match /inventario_piezas/{docId}  { allow read, write: if isSignedIn(); }
    match /poc_logs/{docId}           { allow read, write: if isSignedIn(); }
    match /analytics_piezas_modelo/{docId} { allow read, write: if isSignedIn(); }
    // La cola de correo contiene PII (destinatarios, cuerpos con datos de
    // clientes/contratos). Lectura y administración solo admin/gerente; el
    // `create` queda abierto al staff autenticado porque cotizaciones y órdenes
    // encolan correos vía MailService.enqueue(). El saneo de `attachments`
    // (LFI/SSRF) se hace server-side en functions/src/lib/mail.js.
    match /mail_queue/{docId} {
      allow read:           if isSignedIn() && userRole() in ["administrador","gerente"];
      allow create:         if isSignedIn();
      allow update, delete: if isSignedIn() && userRole() in ["administrador","gerente"];
    }
    match /tecnico_stats/{docId} {
      allow read, write: if isSignedIn();
      match /{sub=**} { allow read, write: if isSignedIn(); }   // mensual, semanal
    }

    // Collection-group query sobre `eventos` (ranking de progreso-tecnicos:
    // UsuariosService.getEventosCountSince → db.collectionGroup('eventos')).
    // OJO: la regla de subcolección con wildcard recursivo de arriba NO autoriza
    // collection-group queries — Firestore exige una regla dedicada con el id de
    // colección como segmento literal precedido por {path=**}. Sin esto la query
    // falla con "Missing or insufficient permissions". El único `eventos` del
    // proyecto vive en tecnico_stats/{key}/eventos (lo escribe el trigger
    // onComplete vía admin SDK), así que basta read para autenticados.
    match /{path=**}/eventos/{eventoId} {
      allow read: if isSignedIn();
    }

    // Solicitudes de reseteo desde login.html. Hoy se intentan SIN sesión y
    // fallan silenciosamente (best-effort, try/catch). Se preserva ese estado.
    match /reset_requests/{docId}     { allow read, write: if isSignedIn(); }

    // ── Integración QuickBooks — SOLO Cloud Functions (admin SDK) ──────────
    // `integraciones/quickbooks` guarda tokens OAuth (access/refresh) y realmId;
    // `integraciones_qbo_oauth_states` son states CSRF efímeros;
    // `qbo_webhook_events` son eventos crudos del webhook entrante.
    // NINGÚN frontend debe leerlos ni escribirlos: deny explícito. Sin catch-all
    // estarían denegadas igual, pero esto lo documenta y previene aflojarlas.
    match /integraciones/{docId}                  { allow read, write: if false; }
    match /integraciones_qbo_oauth_states/{docId} { allow read, write: if false; }
    match /qbo_webhook_events/{docId}             { allow read, write: if false; }
  }
}
