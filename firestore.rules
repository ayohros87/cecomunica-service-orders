rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function userRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }

    // Returns true if the incoming write touches any field owned exclusively by Cloud Functions.
    // Admin SDK (used by CFs) bypasses these rules, so this only blocks frontend writes.
    function touchesCFOwnedFields() {
      let incoming = request.resource.data;
      return ("firma_codigo"        in incoming) ||
             ("firma_hash"          in incoming) ||
             ("firma_url"           in incoming) ||
             ("fecha_aprobacion"    in incoming) ||
             ("os_count"            in incoming) ||
             ("equipos_total"       in incoming) ||
             ("tiene_os"            in incoming) ||
             ("os_linked"           in incoming) ||
             ("os_serials_preview"  in incoming) ||
             ("os_has_equipos"      in incoming) ||
             ("os_last_orden_id"    in incoming) ||
             ("os_equipos_count_last" in incoming) ||
             ("os_dirty"            in incoming);
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    match /usuarios/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /contratos/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && !touchesCFOwnedFields()
        && (!(resource.data.estado != "activo" && request.resource.data.estado == "activo")
            || (userRole() in ["administrador","gerente"]));
      allow delete: if request.auth != null && (userRole() in ["administrador","gerente"]);

      // Cache subcollection — written exclusively by Cloud Functions via admin SDK
      match /ordenes/{ordenId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /verificaciones/{contratoId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
